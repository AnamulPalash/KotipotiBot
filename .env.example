# ============================================================
# KotipotiBot — Environment Variables
# Copy this to .env and fill in real values on the Pi.
# NEVER commit .env to git.
# ============================================================

# Telegram (for alerts and Hermes reports)
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Dashboard admin password. Override this before exposing the dashboard.
ADMIN_PASSWORD=CHANGE_ME

# Custom bot runtime.
DRY_RUN=true
LOG_LEVEL=INFO
DASHBOARD_HOST_PORT=5001
BOT_VARIANT=codex_v1
TAKER_FEE_BPS=5.5
SLIPPAGE_BPS=2.0
