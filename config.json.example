{
  "$schema": "https://schema.freqtrade.io/schema.json",

  "trading_mode": "futures",
  "margin_mode": "isolated",
  "max_open_trades": 3,
  "stake_currency": "USDT",
  "stake_amount": 200,
  "tradable_balance_ratio": 0.99,
  "fiat_display_currency": "USD",

  "dry_run": true,
  "dry_run_wallet": 2000,

  "cancel_open_orders_on_exit": true,

  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "unit": "minutes"
  },

  "exchange": {
    "name": "bybit",
    "key": "YOUR_BYBIT_API_KEY",
    "secret": "YOUR_BYBIT_API_SECRET",
    "ccxt_config": {
      "enableRateLimit": true
    },
    "ccxt_async_config": {},
    "pair_whitelist": [
      "BTC/USDT:USDT",
      "ETH/USDT:USDT",
      "SOL/USDT:USDT",
      "BNB/USDT:USDT",
      "XRP/USDT:USDT"
    ],
    "pair_blacklist": [
      "BNB/.*"
    ]
  },

  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },

  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },

  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],

  "telegram": {
    "enabled": true,
    "token": "YOUR_TELEGRAM_BOT_TOKEN",
    "chat_id": "YOUR_TELEGRAM_CHAT_ID",
    "notification_settings": {
      "status": "on",
      "warning": "on",
      "startup": "on",
      "entry": "on",
      "entry_fill": "on",
      "exit": {
        "roi": "on",
        "emergency_exit": "on",
        "force_exit": "on",
        "exit_signal": "on",
        "trailing_stop_loss": "on",
        "stop_loss": "on",
        "stoploss_on_exchange": "on",
        "custom_exit": "on",
        "partial_exit": "on"
      },
      "exit_cancel": "on",
      "exit_fill": "on",
      "protection_trigger": "off",
      "protection_trigger_global": "on",
      "strategy_msg": "off",
      "show_candle": "off"
    }
  },

  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "YOUR_JWT_SECRET_KEY_CHANGE_ME",
    "ws_token": "YOUR_WS_TOKEN_CHANGE_ME",
    "CORS_origins": [],
    "username": "kotipoti",
    "password": "YOUR_UI_PASSWORD"
  },

  "bot_name": "KotipotiBot",
  "initial_state": "running",
  "force_entry_enable": false,
  "internals": {
    "process_throttle_secs": 5
  },

  "strategy": "ShortScalper",
  "strategy_path": "/freqtrade/user_data/strategies/",

  "datadir": "/freqtrade/user_data/data/bybit",
  "user_data_dir": "/freqtrade/user_data"
}
